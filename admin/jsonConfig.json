{
  "i18n": true,
  "type": "panel",
  "items": {
    "info": {
      "type": "staticText",
      "text": "Bestehende Datenpunkte als Quelle waehlen, Berechnungsart definieren und Ziel-Datenpunktname angeben. Zielname ohne Punkt wird automatisch unter ems.X.calculated.<name> angelegt. Verbrauch-Formel: 'sourceId1 +/- sourceId2 +/- ...' (z.B. 'grid.power - pv.power + battery.power').",
      "newLine": true,
      "sm": 12
    },
    "calculations": {
      "type": "table",
      "label": "Berechnungen",
      "newLine": true,
      "sm": 12,
      "items": [
        {
          "type": "checkbox",
          "attr": "enabled",
          "title": "Aktiv",
          "width": "8%",
          "default": true
        },
        {
          "type": "select",
          "attr": "type",
          "title": "Berechnungsart",
          "width": "12%",
          "options": [
            {
              "label": "Energie",
              "value": "Energie"
            },
            {
              "label": "EnergieTag",
              "value": "EnergieTag"
            },
            {
              "label": "Verbrauch",
              "value": "Verbrauch"
            },
            {
              "label": "Durchschnitt",
              "value": "Durchschnitt"
            }
          ],
          "default": "Energie"
        },
        {
          "type": "objectId",
          "attr": "sourceId",
          "title": "Quell-Datenpunkt",
          "width": "18%",
          "filter": {
            "type": "state"
          },
          "showIf": "{type} !== 'Verbrauch'"
        },
        {
          "type": "text",
          "attr": "verbrauchFormula",
          "title": "Formel (Verbrauch)",
          "width": "18%",
          "placeholder": "source1 + source2 - source3",
          "showIf": "{type} === 'Verbrauch'"
        },
        {
          "type": "text",
          "attr": "targetName",
          "title": "Ziel-Datenpunktname",
          "width": "16%",
          "default": "my_calc"
        },
        {
          "type": "checkbox",
          "attr": "invertValue",
          "title": "Negative invertieren",
          "width": "12%",
          "default": false,
          "showIf": "{type} === 'Energie' || {type} === 'EnergieTag'"
        },
        {
          "type": "number",
          "attr": "averageSeconds",
          "title": "Fenster (Sek.)",
          "width": "10%",
          "min": 1,
          "default": 300,
          "showIf": "{type} === 'Durchschnitt'"
        },
        {
          "type": "checkbox",
          "attr": "onlyPositive",
          "title": "Nur positive",
          "width": "10%",
          "default": true,
          "showIf": "{type} === 'Energie'"
        }
      ]
    }
  }
}

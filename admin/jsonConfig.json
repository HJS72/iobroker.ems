{
  "i18n": true,
  "type": "panel",
  "items": {
    "info": {
      "type": "staticText",
      "text": "Bestehende Datenpunkte als Quelle waehlen, Berechnungsart definieren und Ziel-Datenpunktname angeben. Zielname ohne Punkt wird automatisch unter ems.0.<name> angelegt. Fuer Typ Berechnung steht ein Formel-Editor (JSON-Array aus id/op-Termen) zur Verfuegung.",
      "newLine": true,
      "sm": 12
    },
    "validateConfig": {
      "type": "sendTo",
      "label": "Konfiguration pruefen",
      "adapter": "ems",
      "command": "validateConfig",
      "data": {
        "calculationsJson": "${data._calculationsJson}"
      },
      "useNative": true,
      "showProcess": true,
      "variant": "contained",
      "result": {
        "en": "Configuration check successful",
        "de": "Konfigurationspruefung erfolgreich"
      },
      "error": {
        "en": "Configuration check failed",
        "de": "Konfigurationspruefung fehlgeschlagen"
      },
      "newLine": true,
      "sm": 4
    },
    "validationHint": {
      "type": "staticText",
      "text": "Nach jeder Aenderung bitte zuerst 'Konfiguration pruefen' ausfuehren. Speichern ist erst danach moeglich.",
      "newLine": false,
      "sm": 8
    },
    "_validationPassed": {
      "type": "checkbox",
      "hidden": true,
      "default": false,
      "validator": "data._validationPassed === true",
      "validatorNoSaveOnError": true,
      "validatorErrorText": "Bitte zuerst 'Konfiguration pruefen' ausfuehren.",
      "onChange": {
        "alsoDependsOn": [
          "calculations"
        ],
        "calculateFunc": "return false"
      }
    },
    "_calculationsJson": {
      "type": "text",
      "hidden": true,
      "default": "[]",
      "onChange": {
        "alsoDependsOn": [
          "calculations"
        ],
        "calculateFunc": "return JSON.stringify(data.calculations || [])"
      }
    },
    "calculations": {
      "type": "table",
      "label": "Berechnungen",
      "newLine": true,
      "sm": 12,
      "items": [
        {
          "type": "checkbox",
          "attr": "enabled",
          "title": "Aktiv",
          "width": "7%",
          "default": true
        },
        {
          "type": "select",
          "attr": "type",
          "title": "Berechnungsart",
          "width": "11%",
          "options": [
            {
              "label": "Energie",
              "value": "Energie"
            },
            {
              "label": "EnergieTag",
              "value": "EnergieTag"
            },
            {
              "label": "Berechnung",
              "value": "Berechnung"
            },
            {
              "label": "Durchschnitt",
              "value": "Durchschnitt"
            }
          ],
          "default": "Energie"
        },
        {
          "type": "objectId",
          "attr": "sourceId",
          "title": "Quell-Datenpunkt",
          "width": "20%",
          "customFilter": {
            "type": "state",
            "common": {
              "type": "number"
            }
          },
          "hidden": "data.type === 'Berechnung'"
        },
        {
          "type": "custom",
          "attr": "berechnungFormula",
          "title": "Formel (Berechnung)",
          "width": "32%",
          "url": "custom/customComponents.js",
          "name": "EmsAdminSet/Components/FormulaEditor",
          "bundlerType": "module",
          "validator": "data.type !== 'Berechnung' || !!(data.berechnungFormula || '').trim()",
          "validatorNoSaveOnError": true,
          "validatorErrorText": "Bitte fuer Berechnung eine gueltige Formel eingeben.",
          "hidden": "data.type !== 'Berechnung'"
        },
        {
          "type": "text",
          "attr": "targetName",
          "title": "Ziel-Datenpunktname",
          "width": "10%",
          "default": "my_calc"
        },
        {
          "type": "text",
          "attr": "unit",
          "title": "Einheit",
          "width": "6%",
          "placeholder": "z.B. W, Wh, kWh"
        },
        {
          "type": "checkbox",
          "attr": "invertValue",
          "title": "Negative invertieren",
          "width": "7%",
          "default": false,
          "hidden": "data.type !== 'Energie' && data.type !== 'EnergieTag'"
        },
        {
          "type": "number",
          "attr": "averageSeconds",
          "title": "Fenster (Sek.)",
          "width": "7%",
          "min": 1,
          "default": 300,
          "hidden": "data.type !== 'Durchschnitt'"
        },
        {
          "type": "checkbox",
          "attr": "onlyPositive",
          "title": "Nur positive",
          "width": "7%",
          "default": true,
          "hidden": "data.type !== 'Energie'"
        }
      ]
    }
  }
}
